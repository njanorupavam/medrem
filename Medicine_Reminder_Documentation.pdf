T*
(\\Sdk","User"\)) Tj
T*
([Environment]::SetEnvironmentVariable\("ANDROID_SDK_ROOT","C:\\Users\\kaasi\\AppData\\Local\\And) Tj
T*
(roid\\Sdk","User"\)) Tj
T*
($userPath = [Environment]::GetEnvironmentVariable\("Path","User"\)) Tj
T*
($newPaths = @\() Tj
T*
(  "C:\\Users\\kaasi\\AppData\\Local\\Android\\Sdk\\platform-tools",) Tj
