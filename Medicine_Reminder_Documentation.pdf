T*
(Expand-Archive -Path "$env:TEMP\\cmdline-tools.zip" -DestinationPath "$env:TEMP\\cmdline-) Tj
T*
(tools-extract" -Force) Tj
T*
(Move-Item -Path "$env:TEMP\\cmdline-tools-extract\\cmdline-tools\\*" -Destination ) Tj
T*
("C:\\Users\\kaasi\\AppData\\Local\\Android\\Sdk\\cmdline-tools\\latest" -Force) Tj
T*
